rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Rooms ──────────────────────────────────────────────────────
    match /rooms/{roomId} {
      // Any authenticated user can read rooms
      allow read: if request.auth != null;

      // Only authenticated users can create rooms, and must set createdBy to themselves
      allow create: if request.auth != null
                    && request.resource.data.createdBy == request.auth.uid;

      // Any authenticated user can update a room (for preview, participantUids, reactions, isHighActivity)
      allow update: if request.auth != null;

      // Only the creator can delete
      allow delete: if request.auth != null
                    && resource.data.createdBy == request.auth.uid;

      // Messages sub-collection
      match /messages/{messageId} {
        allow read: if request.auth != null;
        // Any authenticated user can send messages; uid must match their own
        allow create: if request.auth != null
                      && request.resource.data.uid == request.auth.uid;
        // Allow updates (for reactions via arrayUnion)
        allow update: if request.auth != null;
        // Messages cannot be deleted
        allow delete: if false;
      }
    }

    // ── Users ──────────────────────────────────────────────────────
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Activity sub-collection
      match /activity/{activityId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
